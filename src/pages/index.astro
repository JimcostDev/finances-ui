---
import Layout from "@layouts/Layout.astro";
import SessionRedirect from "@components/auth/SessionRedirect.tsx";
---

<Layout title="MyFinances - Gestión Financiera Personal">
  <SessionRedirect client:load />
  <div
    class="min-h-[calc(100vh-6rem)] bg-linear-to-b from-slate-50 via-white to-emerald-50/40"
  >
    <section
      class="mx-auto flex max-w-2xl flex-col justify-center px-6 pb-24 pt-16 sm:px-8 sm:pt-20"
    >
      <p
        class="mb-8 text-center text-[11px] font-medium uppercase tracking-[0.28em] text-slate-500"
      >
        Finanzas personales
      </p>

      <h1
        class="text-balance text-center text-[2.125rem] font-semibold leading-[1.15] tracking-tight text-slate-900 sm:text-5xl sm:leading-[1.1]"
      >
        <span
          class="bg-linear-to-r from-blue-600 to-emerald-600 bg-clip-text text-transparent"
          >Claridad</span
        >
        <span class="text-slate-900"> en cada movimiento</span>
      </h1>

      <p
        class="mx-auto mt-6 max-w-md text-center text-[15px] leading-relaxed text-slate-600 sm:text-base"
      >
        Registra ingresos y gastos, revisa reportes y mantén el control sin
        complicarte.
      </p>

      <div
        class="mt-12 flex flex-col items-stretch justify-center gap-3 sm:flex-row sm:items-center"
      >
        <a
          href="/register"
          class="inline-flex items-center justify-center rounded-xl bg-linear-to-r from-blue-600 to-emerald-600 px-8 py-3.5 text-[15px] font-semibold text-white shadow-md shadow-blue-600/15 transition hover:shadow-lg hover:shadow-blue-600/25"
        >
          Crear cuenta
        </a>
        <a
          href="/login"
          class="inline-flex items-center justify-center rounded-xl border border-slate-200 bg-white/80 px-8 py-3.5 text-[15px] font-medium text-slate-700 backdrop-blur-sm transition hover:border-slate-300 hover:bg-white"
        >
          Entrar
        </a>
      </div>

      <div
        class="mt-16 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-center text-[13px] tracking-wide text-slate-400 sm:mt-20"
      >
        <span class="text-slate-500">Reportes</span>
        <span class="text-slate-300" aria-hidden="true">·</span>
        <span class="text-slate-500">Balance</span>
        <span class="text-slate-300" aria-hidden="true">·</span>
        <span class="text-slate-500">Ofrendas</span>
      </div>
    </section>

    <footer
      class="border-t border-slate-100/80 px-6 py-10 text-center text-[13px] text-slate-500"
    >
      <p>
        © MyFinances ·
        <a
          href="http://www.jimcostdev.com"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-700 underline decoration-slate-300 underline-offset-4 transition hover:text-slate-900"
          >jimcostdev</a
        >
      </p>
    </footer>
  </div>
</Layout>
