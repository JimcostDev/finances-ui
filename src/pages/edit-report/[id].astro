---
import Layout from '../../layouts/Layout.astro';
import EditReportForm from "@components/reports/EditReportForm.tsx";
import SectionContainer from "@components/layout/SectionContainer.astro";

const id = Astro.params.id;
if (!id) {
  return Astro.redirect("/reports");
}
---

<Layout title="Editar Reporte">
    <SectionContainer id="edit-report">
        <EditReportForm client:load reportId={id} />
    </SectionContainer>
</Layout>
