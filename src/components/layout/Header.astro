---
import HeaderNav from "@components/layout/HeaderNav.tsx";

const currentPath = Astro.url.pathname;

const hideHeader = currentPath.startsWith("/dashboard");

if (hideHeader) {
  return null;
}
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200 shadow-sm">
  <nav class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 min-w-0">
    <div class="flex justify-between items-center h-16 gap-2 min-w-0">
      <a href="/" class="flex items-center gap-2 sm:gap-3 group min-w-0 shrink">
        <div class="w-10 h-10 shrink-0 bg-linear-to-br from-blue-600 to-emerald-600 rounded-xl flex items-center justify-center transform group-hover:scale-110 transition-transform duration-300">
          <span class="text-white text-xl font-bold">$</span>
        </div>
        <span class="text-lg sm:text-xl font-bold bg-linear-to-r from-blue-600 to-emerald-600 bg-clip-text text-transparent truncate">
          MyFinances
        </span>
      </a>

      <div class="flex items-center justify-end shrink-0 min-w-0">
        <HeaderNav client:load pathname={currentPath} />
      </div>
    </div>
  </nav>
</header>
