{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"],
  "compilerOptions": {
    "paths": {
      "@components/*": ["./src/components/*"],
      "@styles/*": ["./src/styles/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@utils/*": ["./src/utils/*"],
      "@services": ["./src/services/index.ts"],
      "@services/*": ["./src/services/*"],
      "@interfaces": ["./src/interfaces/index.ts"],
      "@interfaces/*": ["./src/interfaces/*"]
    }
  }
}